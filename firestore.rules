rules_version = '2';

// Auth is now handled by JWT session cookies in the Next.js middleware.
// Firestore is accessed directly by the client SDK (open rules) since
// the app is private and all routes are protected at the middleware layer.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
